{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPutToFirehose",
      "Effect": "Allow",
      "Action": [
        "firehose:PutRecord",
        "firehose:PutRecordBatch"
      ],
      "Resource": "arn:aws:firehose:${AWS_REGION}:${AWS_ACCOUNT_ID}:deliverystream/${DELIVERY_STREAM_NAME}"
    }
  ]
}
