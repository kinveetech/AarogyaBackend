# =============================================================================
# Aarogya Backend - Environment Variables
# =============================================================================
# Copy to .env and customise. Docker Compose reads this file automatically.
# The API also supports AAROGYA_ prefixed variables (e.g. AAROGYA_Jwt__Key)
# which take highest precedence and avoid collisions with other apps.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=aarogya
POSTGRES_USER=aarogya
POSTGRES_PASSWORD=aarogya_dev_password

# --- pgAdmin ------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@aarogya.com
PGADMIN_DEFAULT_PASSWORD=admin

# --- Connection Strings (used by the API container) ---------------------------
DEFAULT_CONNECTION_STRING=Host=postgres;Port=5432;Database=aarogya;Username=aarogya;Password=aarogya_dev_password
REDIS_CONNECTION_STRING=redis:6379

# --- JWT Authentication -------------------------------------------------------
JWT_KEY=development-key-change-this-to-32-plus-chars
JWT_ISSUER=AarogyaAPI
JWT_AUDIENCE=AarogyaClients

# --- AWS (use 'test' values for LocalStack) -----------------------------------
# AWS_ACCESS_KEY=test
# AWS_SECRET_KEY=test
# AWS_REGION=ap-south-1
# AWS_SERVICE_URL=http://localstack:4566

# --- Redis --------------------------------------------------------------------
# REDIS_PASSWORD=
# REDIS_INSTANCE_NAME=aarogya_dev_

# --- CORS (comma-separated origins) ------------------------------------------
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging ------------------------------------------------------------------
# SERILOG_MINIMUM_LEVEL=Debug
