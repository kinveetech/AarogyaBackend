{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=aarogya;Username=aarogya;Password=aarogya_dev_password;Include Error Detail=true",
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000"
  },
  "Jwt": {
    "Key": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "Issuer": "AarogyaAPI",
    "Audience": "AarogyaClients",
    "ExpiryInMinutes": 120
  },
  "Aws": {
    "Region": "ap-south-1",
    "ServiceUrl": "http://localhost:4566",
    "UseLocalStack": true,
    "Cognito": {
      "UserPoolName": "aarogya-dev-users",
      "UserPoolId": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
      "AppClientId": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
      "Issuer": "http://localhost:4566/SET_VIA_USER_SECRETS_OR_ENV_VAR",
      "SocialIdentityProviders": {
        "Google": {
          "Enabled": false
        },
        "Apple": {
          "Enabled": false
        },
        "Facebook": {
          "Enabled": false
        },
        "MobileRedirectUris": [
          "aarogya://auth/callback"
        ]
      },
      "MfaConfiguration": "OPTIONAL",
      "PasswordPolicy": {
        "MinimumLength": 8,
        "RequireLowercase": true,
        "RequireUppercase": true,
        "RequireNumbers": true,
        "RequireSymbols": true
      }
    },
    "S3": {
      "BucketName": "aarogya-dev",
      "PresignedUrlExpiryMinutes": 15,
      "DefaultAcl": "private",
      "CloudFront": {
        "Enabled": false
      }
    },
    "Sqs": {
      "QueueName": "aarogya-dev-queue",
      "ConfigureS3NotificationsOnStartup": true,
      "EnableUploadEventConsumer": true,
      "MaxNumberOfMessages": 5,
      "ReceiveWaitTimeSeconds": 10,
      "VisibilityTimeoutSeconds": 30,
      "EmptyPollDelayMilliseconds": 250
    },
    "Ses": {
      "SenderEmail": "noreply@aarogya.dev",
      "SenderName": "Aarogya Dev"
    }
  },
  "Encryption": {
    "UseAwsKms": false,
    "KmsKeyId": "alias/aarogya-dev-data-key",
    "LocalDataKey": "aarogya-local-dev-encryption-key",
    "BlindIndexKey": "aarogya-local-dev-blind-index-key"
  },
  "AadhaarVault": {
    "UseMockApi": true,
    "MockApiBaseUrl": "http://localhost:5099",
    "ValidateEndpoint": "/api/mock/uidai/validate",
    "TokenizeEndpoint": "/api/mock/uidai/tokenize"
  },
  "SeedData": {
    "EnableOnStartup": true,
    "PatientsCount": 24,
    "DoctorsCount": 6,
    "LabTechniciansCount": 4,
    "AdminsCount": 1,
    "ReportsPerPatient": 3
  },
  "Otp": {
    "CodeLength": 6,
    "CodeExpirySeconds": 300,
    "MaxRequestsPerWindow": 3,
    "RateLimitWindowSeconds": 600
  },
  "Pkce": {
    "AuthorizationCodeExpirySeconds": 300,
    "AccessTokenExpirySeconds": 900,
    "RefreshTokenExpirySeconds": 2592000
  },
  "ApiKeys": {
    "KeyPrefix": "aarogya_lab_dev_",
    "MaxRequestsPerWindow": 240,
    "RateLimitWindowSeconds": 60,
    "DefaultKeyLifetimeDays": 365,
    "RotationOverlapMinutes": 1440
  },
  "AccessGrants": {
    "DefaultExpiryDays": 14,
    "MaxExpiryDays": 90
  },
  "Redis": {
    "InstanceName": "aarogya_dev_",
    "Database": 0,
    "ConnectTimeoutMilliseconds": 5000,
    "ConnectRetry": 3,
    "SyncTimeoutMilliseconds": 5000,
    "DefaultExpirationMinutes": 30,
    "KeyPrefix": "aarogya:dev"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ],
    "AllowCredentials": true
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Database": {
    "CommandTimeoutSeconds": 30,
    "EnableDetailedErrors": true,
    "EnableSensitiveDataLogging": true,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 5,
    "AutoMigrateOnStartup": true,
    "HealthCheckTimeoutSeconds": 5
  },
  "TransportSecurity": {
    "EnforceTls13": false
  },
  "HealthChecks": {
    "EnableDetailedOutput": true
  },
  "RateLimiting": {
    "EnableRateLimiting": false,
    "Auth": {
      "Strategy": "fixed",
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 4,
      "PreferPerUserLimits": true
    },
    "ApiV1": {
      "Strategy": "sliding",
      "PermitLimit": 180,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 6,
      "PreferPerUserLimits": true
    }
  },
  "AllowedHosts": "*"
}
