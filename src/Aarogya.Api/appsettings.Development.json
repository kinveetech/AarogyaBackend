{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=aarogya;Username=aarogya;Password=aarogya_dev_password;Include Error Detail=true",
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000"
  },
  "Jwt": {
    "Key": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "Issuer": "AarogyaAPI",
    "Audience": "AarogyaClients",
    "ExpiryInMinutes": 120
  },
  "Aws": {
    "Region": "ap-south-1",
    "ServiceUrl": "http://localhost:4566",
    "UseLocalStack": true,
    "S3": {
      "BucketName": "aarogya-dev",
      "PresignedUrlExpiryMinutes": 60,
      "DefaultAcl": "private"
    },
    "Ses": {
      "SenderEmail": "noreply@aarogya.dev",
      "SenderName": "Aarogya Dev"
    }
  },
  "Redis": {
    "InstanceName": "aarogya_dev_",
    "Database": 0,
    "ConnectTimeoutMilliseconds": 5000,
    "ConnectRetry": 3,
    "SyncTimeoutMilliseconds": 5000,
    "DefaultExpirationMinutes": 30,
    "KeyPrefix": "aarogya:dev"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ],
    "AllowCredentials": true
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Database": {
    "CommandTimeoutSeconds": 30,
    "EnableDetailedErrors": true,
    "EnableSensitiveDataLogging": true,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 5,
    "AutoMigrateOnStartup": true,
    "HealthCheckTimeoutSeconds": 5
  },
  "HealthChecks": {
    "EnableDetailedOutput": true
  },
  "RateLimiting": {
    "EnableRateLimiting": false
  },
  "AllowedHosts": "*"
}
