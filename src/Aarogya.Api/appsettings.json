{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Aarogya": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/aarogya-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-secret-key-here-minimum-32-characters-long",
    "Issuer": "AarogyaAPI",
    "Audience": "AarogyaClients",
    "ExpiryInMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "Redis": "SET_VIA_USER_SECRETS_OR_ENV_VAR"
  },
  "Redis": {
    "InstanceName": "aarogya_",
    "Database": 0,
    "ConnectTimeoutMilliseconds": 5000,
    "ConnectRetry": 3,
    "SyncTimeoutMilliseconds": 5000,
    "DefaultExpirationMinutes": 30,
    "KeyPrefix": "aarogya:prod"
  },
  "Aws": {
    "Region": "ap-south-1",
    "UseLocalStack": false,
    "Cognito": {
      "UserPoolName": "SET_VIA_ENV_VAR",
      "UserPoolId": "SET_VIA_ENV_VAR",
      "AppClientId": "SET_VIA_ENV_VAR",
      "Issuer": "SET_VIA_ENV_VAR",
      "SocialIdentityProviders": {
        "Google": {
          "Enabled": true,
          "ClientId": "SET_VIA_ENV_VAR",
          "ClientSecret": "SET_VIA_ENV_VAR"
        },
        "Apple": {
          "Enabled": false
        },
        "Facebook": {
          "Enabled": false
        },
        "MobileRedirectUris": [
          "aarogya://auth/callback"
        ]
      },
      "MfaConfiguration": "OPTIONAL",
      "PasswordPolicy": {
        "MinimumLength": 8,
        "RequireLowercase": true,
        "RequireUppercase": true,
        "RequireNumbers": true,
        "RequireSymbols": true
      }
    },
    "S3": {
      "BucketName": "SET_VIA_ENV_VAR",
      "PresignedUrlExpiryMinutes": 15,
      "DefaultAcl": "private",
      "CloudFront": {
        "Enabled": false,
        "DistributionDomain": "SET_VIA_ENV_VAR",
        "KeyPairId": "SET_VIA_ENV_VAR",
        "PrivateKeyPem": "SET_VIA_ENV_VAR"
      }
    },
    "Sqs": {
      "QueueName": "SET_VIA_ENV_VAR",
      "ConfigureS3NotificationsOnStartup": true,
      "EnableUploadEventConsumer": true,
      "MaxNumberOfMessages": 5,
      "ReceiveWaitTimeSeconds": 10,
      "VisibilityTimeoutSeconds": 30,
      "EmptyPollDelayMilliseconds": 250
    },
    "Ses": {
      "SenderEmail": "SET_VIA_ENV_VAR",
      "SenderName": "Aarogya"
    }
  },
  "Encryption": {
    "UseAwsKms": true,
    "KmsKeyId": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "LocalDataKey": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "BlindIndexKey": "SET_VIA_USER_SECRETS_OR_ENV_VAR"
  },
  "AadhaarVault": {
    "UseMockApi": true,
    "MockApiBaseUrl": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "ValidateEndpoint": "/api/mock/uidai/validate",
    "TokenizeEndpoint": "/api/mock/uidai/tokenize"
  },
  "SeedData": {
    "EnableOnStartup": false,
    "PatientsCount": 16,
    "DoctorsCount": 4,
    "LabTechniciansCount": 3,
    "AdminsCount": 1,
    "ReportsPerPatient": 2
  },
  "Otp": {
    "CodeLength": 6,
    "CodeExpirySeconds": 300,
    "MaxRequestsPerWindow": 3,
    "RateLimitWindowSeconds": 600
  },
  "Pkce": {
    "AuthorizationCodeExpirySeconds": 300,
    "AccessTokenExpirySeconds": 900,
    "RefreshTokenExpirySeconds": 2592000
  },
  "ApiKeys": {
    "KeyPrefix": "aarogya_lab_",
    "MaxRequestsPerWindow": 120,
    "RateLimitWindowSeconds": 60,
    "DefaultKeyLifetimeDays": 365,
    "RotationOverlapMinutes": 1440
  },
  "AccessGrants": {
    "DefaultExpiryDays": 30,
    "MaxExpiryDays": 180
  },
  "Database": {
    "CommandTimeoutSeconds": 30,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 5,
    "AutoMigrateOnStartup": false,
    "HealthCheckTimeoutSeconds": 5
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "Auth": {
      "Strategy": "fixed",
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 4,
      "PreferPerUserLimits": true
    },
    "ApiV1": {
      "Strategy": "sliding",
      "PermitLimit": 180,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 6,
      "PreferPerUserLimits": true
    }
  }
}
