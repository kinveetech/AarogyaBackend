{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Aarogya": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/aarogya-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-secret-key-here-minimum-32-characters-long",
    "Issuer": "AarogyaAPI",
    "Audience": "AarogyaClients",
    "ExpiryInMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "Redis": "SET_VIA_USER_SECRETS_OR_ENV_VAR"
  },
  "Redis": {
    "InstanceName": "aarogya_",
    "Database": 0,
    "ConnectTimeoutMilliseconds": 5000,
    "ConnectRetry": 3,
    "SyncTimeoutMilliseconds": 5000,
    "DefaultExpirationMinutes": 30,
    "KeyPrefix": "aarogya:prod"
  },
  "EntityCache": {
    "UserProfileTtlSeconds": 300,
    "AccessGrantTtlSeconds": 120,
    "ReportListingTtlSeconds": 120
  },
  "BreachDetection": {
    "EnableWorker": true,
    "ScanIntervalMinutes": 1,
    "LookbackWindowMinutes": 15,
    "SuspiciousAccessThresholdPerActor": 25,
    "BulkExportThresholdPerActor": 50,
    "SuspiciousActions": [
      "report.viewed",
      "report.listed",
      "emergency_access.report_viewed",
      "emergency_access.report_listed"
    ],
    "BulkExportActions": [
      "report.viewed",
      "report.downloaded",
      "report.download_url.created"
    ],
    "NotifyImpactedUsers": true,
    "NotifyAuthorities": true,
    "AuthorityEmails": []
  },
  "Aws": {
    "Region": "ap-south-1",
    "UseLocalStack": false,
    "Cognito": {
      "UserPoolName": "SET_VIA_ENV_VAR",
      "UserPoolId": "SET_VIA_ENV_VAR",
      "AppClientId": "SET_VIA_ENV_VAR",
      "Issuer": "SET_VIA_ENV_VAR",
      "SocialIdentityProviders": {
        "Google": {
          "Enabled": true,
          "ClientId": "SET_VIA_ENV_VAR",
          "ClientSecret": "SET_VIA_ENV_VAR"
        },
        "Apple": {
          "Enabled": false
        },
        "Facebook": {
          "Enabled": false
        },
        "MobileRedirectUris": [
          "aarogya://auth/callback"
        ]
      },
      "MfaConfiguration": "OPTIONAL",
      "PasswordPolicy": {
        "MinimumLength": 8,
        "RequireLowercase": true,
        "RequireUppercase": true,
        "RequireNumbers": true,
        "RequireSymbols": true
      }
    },
    "S3": {
      "BucketName": "SET_VIA_ENV_VAR",
      "PresignedUrlExpiryMinutes": 15,
      "DefaultAcl": "private",
      "CloudFront": {
        "Enabled": false,
        "DistributionId": "SET_VIA_ENV_VAR",
        "DistributionDomain": "SET_VIA_ENV_VAR",
        "KeyPairId": "SET_VIA_ENV_VAR",
        "PrivateKeyPem": "SET_VIA_ENV_VAR",
        "EnableInvalidationOnDelete": true
      }
    },
    "Sqs": {
      "QueueName": "SET_VIA_ENV_VAR",
      "ConfigureS3NotificationsOnStartup": true,
      "EnableUploadEventConsumer": true,
      "MaxNumberOfMessages": 5,
      "ReceiveWaitTimeSeconds": 10,
      "VisibilityTimeoutSeconds": 30,
      "EmptyPollDelayMilliseconds": 250
    },
    "Ses": {
      "SenderEmail": "SET_VIA_ENV_VAR",
      "SenderName": "Aarogya"
    }
  },
  "Encryption": {
    "UseAwsKms": true,
    "KmsKeyId": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "ActiveKeyId": "kms-primary",
    "LocalDataKey": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "LegacyLocalDataKeys": [],
    "BlindIndexKey": "SET_VIA_USER_SECRETS_OR_ENV_VAR"
  },
  "EncryptionRotation": {
    "EnableBackgroundReEncryption": true,
    "CheckIntervalMinutes": 1440,
    "BatchSize": 250
  },
  "AadhaarVault": {
    "UseMockApi": true,
    "MockApiBaseUrl": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "ValidateEndpoint": "/api/mock/uidai/validate",
    "TokenizeEndpoint": "/api/mock/uidai/tokenize"
  },
  "SeedData": {
    "EnableOnStartup": false,
    "PatientsCount": 16,
    "DoctorsCount": 4,
    "LabTechniciansCount": 3,
    "AdminsCount": 1,
    "ReportsPerPatient": 2
  },
  "Otp": {
    "CodeLength": 6,
    "CodeExpirySeconds": 300,
    "MaxRequestsPerWindow": 3,
    "RateLimitWindowSeconds": 600
  },
  "Pkce": {
    "AuthorizationCodeExpirySeconds": 300,
    "AccessTokenExpirySeconds": 900,
    "RefreshTokenExpirySeconds": 2592000
  },
  "ApiKeys": {
    "KeyPrefix": "aarogya_lab_",
    "MaxRequestsPerWindow": 120,
    "RateLimitWindowSeconds": 60,
    "DefaultKeyLifetimeDays": 365,
    "RotationOverlapMinutes": 1440
  },
  "FirebaseMessaging": {
    "EnableSending": false,
    "Endpoint": "https://fcm.googleapis.com/fcm/send",
    "ServerKey": "SET_VIA_ENV_VAR"
  },
  "EmailNotifications": {
    "EnableTransactionalEmails": false,
    "UnsubscribeBaseUrl": "https://aarogya.app/unsubscribe"
  },
  "SmsNotifications": {
    "EnableCriticalSms": false,
    "MaxSendsPerWindow": 5,
    "RateLimitWindowSeconds": 60,
    "EstimatedCostPerMessageInInr": 0.25
  },
  "AccessGrants": {
    "DefaultExpiryDays": 30,
    "MaxExpiryDays": 180
  },
  "EmergencyAccess": {
    "EnableAutoExpiryWorker": true,
    "AutoExpiryWorkerIntervalMinutes": 5,
    "DefaultDurationHours": 24,
    "MinDurationHours": 24,
    "MaxDurationHours": 48,
    "PreExpiryNotificationLeadMinutes": 60
  },
  "VirusScanning": {
    "EnableScanning": true,
    "QuarantineBucketName": "SET_VIA_USER_SECRETS_OR_ENV_VAR",
    "QuarantinePrefix": "quarantine",
    "DefinitionsRefreshIntervalMinutes": 60
  },
  "PdfExtraction": {
    "EnableExtraction": true,
    "EnableAutoExtractionWorker": true,
    "WorkerIntervalMinutes": 2,
    "BatchSize": 10,
    "MinTextLengthPerPage": 50,
    "MaxRetryAttempts": 3,
    "LlmProvider": "bedrock",
    "OllamaEndpoint": "http://localhost:11434",
    "OllamaModelId": "qwen2.5:14b-instruct",
    "BedrockModelId": "anthropic.claude-sonnet-4-20250514",
    "MaxTokens": 4096,
    "MinConfidenceThreshold": 0.5,
    "StoreRawExtractedText": false
  },
  "FileDeletion": {
    "EnableHardDeleteWorker": true,
    "RetentionDays": 2555,
    "WorkerIntervalMinutes": 60
  },
  "Database": {
    "CommandTimeoutSeconds": 30,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 5,
    "AutoMigrateOnStartup": false,
    "HealthCheckTimeoutSeconds": 5
  },
  "TransportSecurity": {
    "EnforceTls13": true
  },
  "SecurityHeaders": {
    "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'; object-src 'none'",
    "XFrameOptions": "DENY",
    "XContentTypeOptions": "nosniff",
    "ReferrerPolicy": "no-referrer",
    "HstsIncludeSubDomains": true,
    "HstsPreload": true,
    "HstsMaxAgeDays": 730
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "Auth": {
      "Strategy": "fixed",
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 4,
      "PreferPerUserLimits": true
    },
    "ApiV1": {
      "Strategy": "sliding",
      "PermitLimit": 180,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 6,
      "PreferPerUserLimits": true
    }
  }
}
